{% schema %}
{
  "name": "Announcement Banner (Premium)",
  "target": "body",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Text Color", "default": "#1a1a1a" },
    { "type": "range", "id": "opacity", "label": "Blur Opacity", "default": 80, "min": 0, "max": 100, "step": 1, "unit": "%" }
  ]
}
{% endschema %}

{%- assign announcement = shop.metafields.my_app.announcement -%}

{% if announcement %}
<div class="premium-announcement-banner">
  <div class="announcement-glass-content">
    <div class="announcement-content">
      <span class="announcement-tag">NEW!</span>
      <span class="announcement-text">{{ announcement }}</span>
    </div>
  </div>
</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700&display=swap');

  .premium-announcement-banner {
    position: fixed;
    top: 20px;
    left: 50%;
    transform: translateX(-50%);
    width: calc(100% - 40px);
    max-width: 800px;
    z-index: 999999;
    font-family: 'Inter', sans-serif;
    pointer-events: none;
    animation: bannerSlideIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .announcement-glass-content {
    background: rgba(255, 255, 255, 0.75);
    backdrop-filter: blur(14px) saturate(200%);
    -webkit-backdrop-filter: blur(14px) saturate(200%);
    background-color: {{ block.settings.bg_color | color_modify: 'alpha', 0.75 }};
    border: 1px solid rgba(255, 255, 255, 0.4);
    border-radius: 40px;
    padding: 10px 20px;
    box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.15);
    pointer-events: auto;
    display: flex;
    justify-content: center;
    align-items: center;
    transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .announcement-glass-content:hover {
    transform: translateY(-2px);
    box-shadow: 0 15px 50px -15px rgba(0, 0, 0, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.6);
  }

  .announcement-content {
    display: flex;
    align-items: center;
    gap: 14px;
    transition: transform 0.3s ease;
  }

  .announcement-tag {
    background: linear-gradient(135deg, #000 0%, #333 100%);
    color: #fff;
    padding: 4px 12px;
    border-radius: 100px;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.8px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
  }

  .announcement-text {
    color: {{ block.settings.text_color }};
    font-size: 14px;
    font-weight: 600;
    letter-spacing: -0.3px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @keyframes bannerSlideIn {
    0% { transform: translate(-50%, -100px); opacity: 0; }
    100% { transform: translate(-50%, 0); opacity: 1; }
  }

  /* Responsive Fix for Header */
  @media (max-width: 768px) {
    .premium-announcement-banner {
        top: 10px;
        width: calc(100% - 20px);
    }
    .announcement-text {
        font-size: 12px;
    }
  }
</style>
{% endif %}
